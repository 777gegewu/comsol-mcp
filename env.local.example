# COMSOL GUI MCP settings.
# Start COMSOL Desktop manually before using this MCP.
COMSOL_GUI_PROCESS_NAMES=ComsolUI.exe,comsol.exe
COMSOL_GUI_WINDOW_TITLE_PATTERN=COMSOL
COMSOL_JAVA_SHELL_TITLE_PATTERN=Java Shell
COMSOL_GUI_TIMEOUT_SEC=10
COMSOL_GUI_DESCENDANT_LIMIT=1200
COMSOL_GUI_SHELL_SCAN_TIMEOUT_SEC=8
# Keep disabled by default. COMSOL localized ribbon automation can be unstable.
COMSOL_GUI_AUTO_OPEN_SHELL=0
COMSOL_GUI_WINDOW_LIST_LIMIT=20
